{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "types": ["jest", "node"],
    "composite": true,
    "noPropertyAccessFromIndexSignature": false,
    "tsBuildInfoFile": "dist/tsconfig.spec.tsbuildinfo"
  },
  "include": ["src/**/*.test.ts", "src/**/*.spec.ts", "src/**/*.d.ts"]
}
