{
  "include": ["eslint.config.mjs"],
  "compilerOptions": {
    "lib": ["es2018"],
    "module": "commonjs",
    "target": "es2018",

    "strict": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "allowJs": true,
    "resolveJsonModule": true,

    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@lib/*": ["lib/src/*"],
      "@bot/*": ["bot/src/*"],
      "@results/*": ["results/src/*"]
    }
  },
  "ts-node": {
    "files": true,
    "require": ["dotenv/config"]
  }
}
