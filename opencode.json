{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": "allow",
    "doom_loop": "allow"
  },
  "compaction": {
    "reserved": 3000,
    "prune": true
  },
  "provider": {
    "homelab": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Homelab LiteLLM (spark)",
      "options": {
        "baseURL": "https://llm.lan.jlapenna.net/v1",
        "apiKey": "{env:OPENCODE_LLM_API_KEY}"
      },
      "models": {
        "default": {
          "name": "Spark Default (Gemma-4 31B, pinned production route — no swap dependency)",
          "limit": {
            "context": 24000,
            "output": 2048
          }
        }
      }
    }
  }
}
