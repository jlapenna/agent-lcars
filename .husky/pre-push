#!/bin/bash

set -e

export NX_TUI=false
export NX_DAEMON=false

branch="$(git rev-parse --abbrev-ref HEAD)"

if [ "$branch" = "main" ]; then
  echo "======================================================================"
  echo "ERROR: direct pushes to main are forbidden."
  echo "Create a feature branch and submit changes through a pull request."
  echo "======================================================================"
  exit 1
fi

./tools/check-dependencies.sh
./tools/nx format:check --base=origin/main
./tools/nx affected -t typecheck --base=origin/main
