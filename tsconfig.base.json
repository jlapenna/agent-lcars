{
  "compilerOptions": {
    "composite": false,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@repo/source"],
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@repo/firestore": ["libs/firestore/src/index.ts"],
      "@repo/firestore/*": ["libs/firestore/src/*"],
      "@repo/youtube": ["libs/youtube/src/index.ts"],
      "@repo/youtube/*": ["libs/youtube/src/*"],
      "@repo/squareup": ["libs/squareup/src/index.ts"],
      "@repo/squareup/*": ["libs/squareup/src/*"],

      "@repo/util": ["libs/util/src/index.ts"],
      "@repo/util/*": ["libs/util/src/*"],
      "@repo/jsx": ["libs/jsx/src/index.ts"],
      "@repo/jsx/*": ["libs/jsx/src/*"],
      "@repo/app": ["./libs/app/src/index.ts"],
      "@repo/app/proxy": ["./libs/app/src/proxy/index.ts"],
      "@repo/chores": ["./libs/chores/src/index.ts"],
      "@repo/chores/*": ["./libs/chores/src/*"],
      "@repo/competitions": ["./libs/competitions/src/index.ts"],
      "@repo/competitions/schema": ["./libs/competitions/src/schema/index.ts"],
      "@repo/competitions/server": ["./libs/competitions/src/server/index.ts"],
      "@repo/competitions/ui": ["./libs/competitions/src/ui/index.ts"],
      "@repo/export-sheets": ["./libs/export-sheets/src/index.ts"],
      "@repo/export-sheets/*": ["./libs/export-sheets/src/*"],
      "@repo/ghost": ["libs/ghost/src/index.ts"],
      "@repo/logging": ["libs/logging/src/index.ts"],
      "@repo/logging/browser": ["libs/logging/src/browser/index.ts"],
      "@repo/logging/error-reporting": ["libs/logging/src/error-reporting.ts"],
      "@repo/logging/server": ["libs/logging/src/server/index.ts"],
      "@repo/provider-service": ["./libs/provider-service/src/index.ts"],
      "@repo/provider-service/*": ["./libs/provider-service/src/*"],
      "@repo/qbp": ["./libs/qbp/src/index.ts"],
      "@repo/qbp/*": ["./libs/qbp/src/*"],
      "@repo/race-events": ["./libs/race-events/src/index.ts"],
      "@repo/race-events/*": ["./libs/race-events/src/*"],
      "@repo/races": ["./libs/races/src/index.ts"],
      "@repo/races/*": ["./libs/races/src/*"],
      "@repo/strava": ["./libs/strava/src/index.ts"],
      "@repo/strava/*": ["./libs/strava/src/*"],
      "@repo/service-auth": ["libs/service-auth/src/index.ts"],
      "@repo/service-auth/*": ["libs/service-auth/src/*"],
      "@repo/test-utils": ["libs/test-utils/src/index.ts"],
      "@repo/test-utils/*": ["libs/test-utils/src/*"],
      "@repo/auth": ["libs/auth/src/index.ts"],
      "@repo/auth/server": ["libs/auth/src/server/index.ts"],
      "@repo/auth/client": ["libs/auth/src/client/index.ts"],
      "@repo/authjs-paths": ["libs/authjs-paths/src/index.ts"],
      "@repo/cloudevents": ["libs/cloudevents/src/index.ts"],
      "@repo/env": ["libs/env-vars/src/index.ts"],
      "@repo/secrets": ["libs/secrets/src/index.ts"],
      "@repo/workspace-plugin": ["./tools/workspace-plugin/src/index.ts"],
      "@repo/firebase-server": ["libs/firebase-server/src/index.ts"],
      "@repo/instagram": ["libs/instagram/src/index.ts"],
      "@repo/google": ["libs/google/src/index.ts"],
      "@repo/invites": ["./libs/invites/src/index.ts"],
      "@repo/invites/*": ["./libs/invites/src/*"],
      "@repo/onboarding": ["./libs/onboarding/src/index.ts"],
      "@repo/onboarding/*": ["./libs/onboarding/src/*"],
      "@repo/racer-claims": ["./libs/racer-claims/src/index.ts"],
      "@repo/racer-claims/*": ["./libs/racer-claims/src/*"],
      "@repo/rag": ["libs/rag/src/index.ts"],
      "@repo/rag/*": ["libs/rag/src/*"],
      "@repo/results": ["./libs/results/src/index.ts"],
      "@repo/results/*": ["./libs/results/src/*"],
      "@repo/riders": ["./libs/riders/src/index.ts"],
      "@repo/riders/*": ["./libs/riders/src/*"],
      "@repo/slack": ["./libs/slack/src/index.ts"],
      "@repo/slack/*": ["./libs/slack/src/*"],
      "@repo/slack-types": ["./libs/slack-types/src/index.ts"],
      "@repo/slack-types/*": ["./libs/slack-types/src/*"],
      "@repo/assistant": ["libs/assistant/src/index.ts"],
      "@repo/util-server": ["libs/util-server/src/index.ts"],
      "@repo/util-server/*": ["libs/util-server/src/*"],
      "@repo/cli/*": ["apps/cli/src/*"],
      "@repo/stripe": ["libs/stripe/src/index.ts"],
      "@repo/app-providers": ["./libs/app-providers/src/index.ts"]
    }
  }
}
