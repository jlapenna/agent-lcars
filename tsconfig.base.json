{
  "compilerOptions": {
    "composite": false,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@repo/source"],
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@repo/util": ["libs/util/src/index.ts"],
      "@repo/util/*": ["libs/util/src/*"],
      "@repo/logging": ["libs/logging/src/index.ts"],
      "@repo/logging/browser": ["libs/logging/src/browser/index.ts"],
      "@repo/logging/error-reporting": ["libs/logging/src/error-reporting.ts"],
      "@repo/logging/server": ["libs/logging/src/server/index.ts"],
      "@repo/test-utils/*": ["libs/test-utils/src/*"],
      "@repo/env": ["libs/env-vars/src/index.ts"],
      "@repo/util-server": ["libs/util-server/src/index.ts"],
      "@repo/util-server/*": ["libs/util-server/src/*"],
      "@repo/app-providers": ["libs/app-providers/src/index.ts"],
      "@agent-lcars/telemetry": ["libs/telemetry/src/index.ts"],
      "@agent-lcars/telemetry/server": ["libs/telemetry/src/server/index.ts"]
    }
  }
}
