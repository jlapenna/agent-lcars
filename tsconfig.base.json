      "@members/shared/google/calendar": [
        "libs/shared/src/google/calendar/index.ts"
      ],
      "@members/shared/instagram": ["libs/shared/src/instagram/index.ts"],
      "@members/shared/logging": ["libs/shared/src/logging/index.ts"],
