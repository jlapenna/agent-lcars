{
  "name": "members",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "bot",
    "functions",
    "lib",
    "results"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "lint:fix": "npm run lint:fix --workspaces",
    "lint-staged": "npm run lint-staged --workspaces",
    "deploy": "./tools/deploy.sh && npm run deploy --workspaces",
    "prepare": "husky"
  },
  "devDependencies": {
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "husky": "^9.1.4",
    "lint-staged": "^15.2.8",
    "prettier-eslint": "^16.3.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.0.0"
  },
  "lint-staged": {
    "*.js": "eslint --cache --fix",
    "*.ts": "eslint --cache --fix --max-warnings=0"
  }
}
