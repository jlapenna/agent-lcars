    "bottleneck": "^2.19.5",
    "chokidar": "^5.0.0",
    "cls-rtracer": "^2.6.3",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "express": "^5.2.1",
    "firebase": "^12.12.0",
    "firebase-admin": "^14.0.0",
    "google-auth-library": "^10.6.2",
    "google-gax": "5.0.7",
    "next": "~16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "yargs": "^18.0.0",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@firebase/util",
      "@google/genai",
      "@parcel/watcher",
