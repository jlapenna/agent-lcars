{
  "name": "@repo/source",
  "version": "0.0.0",
  "license": "Apache-2.0",
  "scripts": {
    "check:dependencies": "./tools/check-dependencies.sh",
    "format": "nx format:write --all",
    "format:check": "nx format:check --all",
    "lint": "nx run-many -t lint --all",
    "postinstall": "patch-package; . tools/cloud-build-prebuild.sh",
    "prepare": "if [ -z \"$CI\" ]; then pnpm exec husky; fi",
    "tsc": "nx run-many -t typecheck",
    "lint:circular": "madge --circular --extensions ts,tsx --ts-config tsconfig.base.json --exclude '.*(dist|test|spec).*' libs/ apps/",
    "verify": "pnpm format:check && pnpm lint && pnpm lint:circular && nx run-many -t test typecheck build --all"
  },
  "private": true,
  "packageManager": "pnpm@10.34.5",
  "engines": {
    "node": "24",
    "pnpm": "10.34.5"
  },
  "dependencies": {
