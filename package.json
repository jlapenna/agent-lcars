    "@nx/next": "23.1.0",
    "@nx/playwright": "23.1.0",
    "@nx/react": "23.1.0",
    "@nx/vite": "23.1.0",
    "@nx/vitest": "23.1.0",
    "@playwright/test": "^1.59.1",
    "@swc/core": "1.15.46",
    "@swc/helpers": "0.5.23",
    "@testing-library/dom": "10.4.1",
