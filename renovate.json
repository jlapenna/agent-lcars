{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "monorepo:nx",
    "monorepo:nextjs",
    "monorepo:react"
  ],
  "labels": ["dependencies"],
  "platformAutomerge": true,
  "rebaseWhen": "conflicted",
  "schedule": ["after 8pm on monday"],
  "packageRules": [
    {
      "description": "Keep pnpm on the supported 10.x line until the runtime toolchain is upgraded deliberately",
      "enabled": false,
      "matchPackageNames": ["pnpm"],
      "matchUpdateTypes": ["major"]
    },
    {
      "description": "Group and automerge updates that preserve the declared compatibility range",
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "groupName": "all non-major dependencies",
      "groupSlug": "all-minor-patch",
      "automerge": true,
      "automergeType": "pr"
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  }
}
